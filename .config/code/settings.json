{
  // STAR --- Extensions:
  // - Color Highlight, by Sergii N
  // - Min Theme, by Miguel Solorio
  // - Symbols, by Miguel Solorio
  // --- END
  "files.autoSave": "afterDelay",
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.startupEditor": "newUntitledFile",
  //
  "editor.fontSize": 12,
  "editor.lineHeight": 1.6,
  "editor.fontFamily": "Jetbrains Mono",
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.rulers": [80, 120],
  "editor.renderLineHighlight": "gutter",
  "workbench.iconTheme": "symbols",
  "workbench.colorTheme": "Min Dark",
  //
  "editor.semanticHighlighting.enabled": false,
  "editor.minimap.enabled": false,
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "symbols.hidesExplorerArrows": false,
  "explorer.compactFolders": false,
  "breadcrumbs.enabled": false,
  "window.menuBarVisibility": "toggle",
  "workbench.statusBar.visible": true,
  "explorer.fileNesting.enabled": true,
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.fontFamily": "Jetbrains Mono",
  //
  "workbench.colorCustomizations": {
    "terminal.foreground": "#cccccc",
    "terminal.background": "#0c0c0c",
    "terminal.ansiBlack": "#0c0c0c",
    "terminal.ansiBlue": "#0037da",
    "terminal.ansiCyan": "#3a96dd",
    "terminal.ansiGreen": "#13a10e",
    "terminal.ansiMagenta": "#88159d",
    "terminal.ansiRed": "#c50f1f",
    "terminal.ansiWhite": "#cccccc",
    "terminal.ansiYellow": "#c19c00",
    "terminal.ansiBrightBlack": "#767676",
    "terminal.ansiBrightBlue": "#3b78ff",
    "terminal.ansiBrightCyan": "#61d6d6",
    "terminal.ansiBrightGreen": "#16c60c",
    "terminal.ansiBrightMagenta": "#b4009e",
    "terminal.ansiBrightRed": "#e53e5e",
    "terminal.ansiBrightWhite": "#f1f1f1",
    "terminal.ansiBrightYellow": "#f9f1a1",
    "terminal.selectionBackground": "#bfdbfe",
    "terminalCursor.background": "#bfdbfe",
    "terminalCursor.foreground": "#3b78ff",
  },
  //
  "telemetry.enableCrashReporter": false,
  "telemetry.enableTelemetry": false,
  //
  "gitlens.currentLine.enabled": false,
  "liveServer.settings.donotShowInfoMsg": true,
  "window.titleBarStyle": "native",
  "apc.header": {
    "height": 36
  },
  "apc.listRow": {
    "height": 24
  },
  "apc.font.family": "Inter",
  "apc.stylesheet": {
    ".title-label > h2": "display: none",
    ".editor-actions": "display: none",
    ".nosidebar .inline-tabs-placeholder": "width: 75px",
    ".pane-header": "padding: 0 8px",
    ".pane-body": "padding: 8px",
    ".split-view-view:first-child .pane-header": "display: none !important;",
    ".monaco-list-row": "border-radius: 4px;",
    ".monaco-workbench .monaco-list:not(.element-focused):focus:before": "display: none;"
  },
  "git.ignoreLimitWarning": true,
  "workbench.activityBar.location": "hidden",
  "git.openRepositoryInParentFolders": "never"
}
